
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @description Rules for user profiles.  Users can read and write their own profile data.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // No one can list all users.
      allow write: if isOwner(userId);

      // Rules for all subcollections under a user's document
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    /**
     * @description Rules for user profile images.
     * - Anyone can read profile images (for public display).
     * - Only the authenticated owner can upload their own profile image.
     * - Uploads are restricted to a maximum size of 5MB.
     * @path /profile-images/{userId}/{fileName}
     */
    match /profile-images/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId && request.resource.size < 5 * 1024 * 1024;
    }
  }
}

// Helper Functions (Firestore ONLY)

function isSignedIn() {
  return request.auth != null;
}

function isOwner(userId) {
  return isSignedIn() && request.auth.uid == userId;
}
