/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy: This ruleset enforces a strict user-ownership model. Each user has full control over the data they create.
 *
 * Data Structure:
 * - Clients: Stored under `/users/{userId}/clients/{clientId}`. Each client is owned by a specific user.
 * - Budgets: Stored under `/users/{userId}/clients/{clientId}/budgets/{budgetId}`. Each budget is associated with a client and owned by a specific user.
 * - DailyRates: Stored under `/users/{userId}/dailyRates/{dailyRateId}`. Each daily rate is owned by a specific user.
 *
 * Key Security Decisions:
 * - Users can only access data under their own user ID path.
 * - Listing of user-owned collections is allowed for the owner.
 *
 * Denormalization for Authorization:
 * - The data is structured such that authorization checks only need to inspect the document path,
 *   rather than requiring `get()` operations to fetch data from other documents. This ensures
 *   efficient and secure rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is made by a signed-in user.
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the request is made by the owner of the resource.
     * @param {string} userId - The user ID of the owner.
     * @return {bool} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the request is made by an existing owner of the resource.
     * @param {string} userId - The user ID of the owner.
     * @return {bool} True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for the /users/{userId}/clients/{clientId} collection.
     * @path /users/{userId}/clients/{clientId}
     * @allow (create) A user with UID 'user123' can create a client document with ID 'client456' under /users/user123/clients/client456.
     * @allow (get) A user with UID 'user123' can read a client document with ID 'client456' under /users/user123/clients/client456.
     * @allow (list) A user with UID 'user123' can list client documents under /users/user123/clients.
     * @allow (update) A user with UID 'user123' can update a client document with ID 'client456' under /users/user123/clients/client456.
     * @allow (delete) A user with UID 'user123' can delete a client document with ID 'client456' under /users/user123/clients/client456.
     * @deny (create) A user with UID 'user456' cannot create a client document under /users/user123/clients/client456.
     * @deny (get) A user with UID 'user456' cannot read a client document under /users/user123/clients/client456.
     * @deny (list) A user with UID 'user456' cannot list client documents under /users/user123/clients.
     * @deny (update) A user with UID 'user456' cannot update a client document under /users/user123/clients/client456.
     * @deny (delete) A user with UID 'user456' cannot delete a client document under /users/user123/clients/client456.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/clients/{clientId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == clientId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /users/{userId}/clients/{clientId}/budgets/{budgetId} collection.
     * @path /users/{userId}/clients/{clientId}/budgets/{budgetId}
     * @allow (create) A user with UID 'user123' can create a budget document with ID 'budget789' under /users/user123/clients/client456/budgets/budget789.
     * @allow (get) A user with UID 'user123' can read a budget document with ID 'budget789' under /users/user123/clients/client456/budgets/budget789.
     * @allow (list) A user with UID 'user123' can list budget documents under /users/user123/clients/client456/budgets.
     * @allow (update) A user with UID 'user123' can update a budget document with ID 'budget789' under /users/user123/clients/client456/budgets/budget789.
     * @allow (delete) A user with UID 'user123' can delete a budget document with ID 'budget789' under /users/user123/clients/client456/budgets/budget789.
     * @deny (create) A user with UID 'user456' cannot create a budget document under /users/user123/clients/client456/budgets/budget789.
     * @deny (get) A user with UID 'user456' cannot read a budget document under /users/user123/clients/client456/budgets/budget789.
     * @deny (list) A user with UID 'user456' cannot list budget documents under /users/user123/clients/client456/budgets.
     * @deny (update) A user with UID 'user456' cannot update a budget document under /users/user123/clients/client456/budgets/budget789.
     * @deny (delete) A user with UID 'user456' cannot delete a budget document under /users/user123/clients/client456/budgets/budget789.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/clients/{clientId}/budgets/{budgetId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == budgetId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /users/{userId}/dailyRates/{dailyRateId} collection.
     * @path /users/{userId}/dailyRates/{dailyRateId}
     * @allow (create) A user with UID 'user123' can create a daily rate document with ID 'rate789' under /users/user123/dailyRates/rate789.
     * @allow (get) A user with UID 'user123' can read a daily rate document with ID 'rate789' under /users/user123/dailyRates/rate789.
     * @allow (list) A user with UID 'user123' can list daily rate documents under /users/user123/dailyRates.
     * @allow (update) A user with UID 'user123' can update a daily rate document with ID 'rate789' under /users/user123/dailyRates/rate789.
     * @allow (delete) A user with UID 'user123' can delete a daily rate document with ID 'rate789' under /users/user123/dailyRates/rate789.
     * @deny (create) A user with UID 'user456' cannot create a daily rate document under /users/user123/dailyRates/rate789.
     * @deny (get) A user with UID 'user456' cannot read a daily rate document under /users/user123/dailyRates/rate789.
     * @deny (list) A user with UID 'user456' cannot list daily rate documents under /users/user123/dailyRates.
     * @deny (update) A user with UID 'user456' cannot update a daily rate document under /users/user123/dailyRates/rate789.
     * @deny (delete) A user with UID 'user456' cannot delete a daily rate document under /users/user123/dailyRates/rate789.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/dailyRates/{dailyRateId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == dailyRateId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }
  }
}