/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model.  Each user has full
 * control over the data stored under their respective user ID.
 *
 * Data Structure:
 * Data is organized under the /users/{userId} path.  Clients, Budgets and DailyRates
 * are stored under the user's path.
 *   - /users/{userId}/clients/{clientId}
 *   - /users/{userId}/clients/{clientId}/budgets/{budgetId}
 *   - /users/{userId}/dailyRates/{dailyRateId}
 *
 * Key Security Decisions:
 * - Users can only access data under their own user ID.
 * - Listing all users or all data across users is disallowed.
 * - Data validation is relaxed to allow for rapid prototyping and iteration,
 *   focusing on authorization and relational integrity checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     * @return {boolean} True if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource.
     * @param {string} userId The user ID to compare against the request's auth UID.
     * @return {boolean} True if the user is the owner.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource, and that the resource exists.
     * @param {string} userId The user ID to compare against the request's auth UID.
     * @return {boolean} True if the user is the owner and the resource exists.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces user-ownership for Clients.
     * @path /users/{userId}/clients/{clientId}
     * @allow (create) Authenticated user with matching userId in path creates a new client.
     * @allow (get, list) Authenticated user requests their own client.
     * @allow (update, delete) Authenticated user updates/deletes their own existing client.
     * @deny (create) Unauthenticated user attempts to create a client.
     * @deny (get, list) Authenticated user attempts to access another user's client.
     * @deny (update, delete) Authenticated user attempts to update/delete another user's client.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/clients/{clientId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == clientId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces user-ownership for Budgets.
     * @path /users/{userId}/clients/{clientId}/budgets/{budgetId}
     * @allow (create) Authenticated user with matching userId in path creates a new budget.
     * @allow (get, list) Authenticated user requests their own budget.
     * @allow (update, delete) Authenticated user updates/deletes their own existing budget.
     * @deny (create) Unauthenticated user attempts to create a budget.
     * @deny (get, list) Authenticated user attempts to access another user's budget.
     * @deny (update, delete) Authenticated user attempts to update/delete another user's budget.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/clients/{clientId}/budgets/{budgetId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == budgetId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces user-ownership for DailyRates.
     * @path /users/{userId}/dailyRates/{dailyRateId}
     * @allow (create) Authenticated user with matching userId in path creates a new dailyRate.
     * @allow (get, list) Authenticated user requests their own dailyRate.
     * @allow (update, delete) Authenticated user updates/deletes their own existing dailyRate.
     * @deny (create) Unauthenticated user attempts to create a dailyRate.
     * @deny (get, list) Authenticated user attempts to access another user's dailyRate.
     * @deny (update, delete) Authenticated user attempts to update/delete another user's dailyRate.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/dailyRates/{dailyRateId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == dailyRateId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Denies listing the entire budgets collection.  This addresses the reported error.
     * @path /budgets
     * @deny (list)  Any attempt to list the budgets collection.
     * @principle Avoid public listing of private collections.  The "budgets" collection is intended
     *            to be private to each user.
     */
    match /budgets {
        allow get: if false;
        allow list: if false;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
    }
  }
}