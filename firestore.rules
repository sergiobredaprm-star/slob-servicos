/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model.  Users can only
 * access data that they explicitly own.  Schema validation is relaxed
 * for rapid prototyping, focusing instead on authorization.
 *
 * Data Structure:
 * - /users/{userId}: User profiles, accessible only by the user themselves.
 * - /users/{userId}/clients/{clientId}: Clients owned by a specific user.
 * - /users/{userId}/budgets/{budgetId}: Budgets owned by a specific user.
 * - /users/{userId}/dailyRates/{dailyRateId}: Daily rates owned by a specific user.
 * - /users/{userId}/companyProfile/{profileId}: Company Profile owned by a specific user.
 *
 * Key Security Decisions:
 * - Users cannot list all user profiles (to protect privacy).
 * - All write operations are validated against user ownership.
 * - Data validation is minimal, focusing on ownership and relational integrity.
 * - No global admin roles are defined in this ruleset.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Rules for user profiles.  Users can read and write their own profile data.
     * @path /users/{userId}
     * @allow (get) User 'bob@example.com' (uid: 'bob') can read their own profile at /users/bob.
     * @deny (get) User 'alice@example.com' (uid: 'alice') cannot read bob's profile at /users/bob.
     * @allow (create) User 'bob@example.com' (uid: 'bob') can create their profile at /users/bob.
     * @deny (create) User 'alice@example.com' (uid: 'alice') cannot create a profile at /users/bob.
     * @allow (update) User 'bob@example.com' (uid: 'bob') can update their own profile at /users/bob.
     * @deny (update) User 'alice@example.com' (uid: 'alice') cannot update bob's profile at /users/bob.
     * @allow (delete) User 'bob@example.com' (uid: 'bob') can delete their own profile at /users/bob.
     * @deny (delete) User 'alice@example.com' (uid: 'alice') cannot delete bob's profile at /users/bob.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      // Read rules: Only the owner can read their profile.
      allow get: if isOwner(userId);
      // List rule:  No one can list all users.
      allow list: if false;

      // Write rules: Only the owner can create, update, or delete their profile.
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for clients owned by a user.  Only the owner can create, read, update, and delete their clients.
     * @path /users/{userId}/clients/{clientId}
     * @allow (create) User 'bob@example.com' (uid: 'bob') can create a client under /users/bob/clients/client1.
     * @deny (create) User 'alice@example.com' (uid: 'alice') cannot create a client under /users/bob/clients/client1.
     * @allow (get) User 'bob@example.com' (uid: 'bob') can read a client under /users/bob/clients/client1.
     * @deny (get) User 'alice@example.com' (uid: 'alice') cannot read a client under /users/bob/clients/client1.
     * @allow (update) User 'bob@example.com' (uid: 'bob') can update a client under /users/bob/clients/client1.
     * @deny (update) User 'alice@example.com' (uid: 'alice') cannot update a client under /users/bob/clients/client1.
     * @allow (delete) User 'bob@example.com' (uid: 'bob') can delete a client under /users/bob/clients/client1.
     * @deny (delete) User 'alice@example.com' (uid: 'alice') cannot delete a client under /users/bob/clients/client1.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/clients/{clientId} {
      // Read rules: Only the owner can read and list their clients.
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      // Write rules: Only the owner can create, update, or delete their clients.
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for budgets owned by a user. Only the owner can create, read, update, and delete their budgets.
     * @path /users/{userId}/budgets/{budgetId}
     * @allow (create) User 'bob@example.com' (uid: 'bob') can create a budget under /users/bob/budgets/budget1.
     * @deny (create) User 'alice@example.com' (uid: 'alice') cannot create a budget under /users/bob/budgets/budget1.
     * @allow (get) User 'bob@example.com' (uid: 'bob') can read a budget under /users/bob/budgets/budget1.
     * @deny (get) User 'alice@example.com' (uid: 'alice') cannot read a budget under /users/bob/budgets/budget1.
     * @allow (update) User 'bob@example.com' (uid: 'bob') can update a budget under /users/bob/budgets/budget1.
     * @deny (update) User 'alice@example.com' (uid: 'alice') cannot update a budget under /users/bob/budgets/budget1.
     * @allow (delete) User 'bob@example.com' (uid: 'bob') can delete a budget under /users/bob/budgets/budget1.
     * @deny (delete) User 'alice@example.com' (uid: 'alice') cannot delete a budget under /users/bob/budgets/budget1.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/budgets/{budgetId} {
      // Read rules: Only the owner can read and list their budgets.
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      // Write rules: Only the owner can create, update, or delete their budgets.
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for daily rates owned by a user.  Only the owner can create, read, update, and delete their daily rates.
     * @path /users/{userId}/dailyRates/{dailyRateId}
     * @allow (create) User 'bob@example.com' (uid: 'bob') can create a daily rate under /users/bob/dailyRates/rate1.
     * @deny (create) User 'alice@example.com' (uid: 'alice') cannot create a daily rate under /users/bob/dailyRates/rate1.
     * @allow (get) User 'bob@example.com' (uid: 'bob') can read a daily rate under /users/bob/dailyRates/rate1.
     * @deny (get) User 'alice@example.com' (uid: 'alice') cannot read a daily rate under /users/bob/dailyRates/rate1.
     * @allow (update) User 'bob@example.com' (uid: 'bob') can update a daily rate under /users/bob/dailyRates/rate1.
     * @deny (update) User 'alice@example.com' (uid: 'alice') cannot update a daily rate under /users/bob/dailyRates/rate1.
     * @allow (delete) User 'bob@example.com' (uid: 'bob') can delete a daily rate under /users/bob/dailyRates/rate1.
     * @deny (delete) User 'alice@example.com' (uid: 'alice') cannot delete a daily rate under /users/bob/dailyRates/rate1.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/dailyRates/{dailyRateId} {
      // Read rules: Only the owner can read and list their daily rates.
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      // Write rules: Only the owner can create, update, or delete their daily rates.
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for company profiles owned by a user. Only the owner can create, read, update, and delete their company profile.
     * @path /users/{userId}/companyProfile/{profileId}
     * @allow (create) User 'bob@example.com' (uid: 'bob') can create a company profile under /users/bob/companyProfile/profile1.
     * @deny (create) User 'alice@example.com' (uid: 'alice') cannot create a company profile under /users/bob/companyProfile/profile1.
     * @allow (get) User 'bob@example.com' (uid: 'bob') can read a company profile under /users/bob/companyProfile/profile1.
     * @deny (get) User 'alice@example.com' (uid: 'alice') cannot read a company profile under /users/bob/companyProfile/profile1.
     * @allow (list) User 'bob@example.com' (uid: 'bob') can list company profiles under /users/bob/companyProfile
     * @deny (list) User 'alice@example.com' (uid: 'alice') cannot list company profiles under /users/bob/companyProfile
     * @allow (update) User 'bob@example.com' (uid: 'bob') can update a company profile under /users/bob/companyProfile/profile1.
     * @deny (update) User 'alice@example.com' (uid: 'alice') cannot update a company profile under /users/bob/companyProfile/profile1.
     * @allow (delete) User 'bob@example.com' (uid: 'bob') can delete a company profile under /users/bob/companyProfile/profile1.
     * @deny (delete) User 'alice@example.com' (uid: 'alice') cannot delete a company profile under /users/bob/companyProfile/profile1.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/companyProfile/{profileId} {
      // Read rules: Only the owner can read and list their company profile.
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      // Write rules: Only the owner can create, update, or delete their company profile.
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
  }

  // Helper functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return isSignedIn() && request.auth.uid == userId;
  }

  function isExistingOwner(userId) {
    return isOwner(userId) && resource != null;
  }
}