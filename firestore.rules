/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. All data is nested under
 * /users/{userId}, ensuring that only the authenticated user can access their
 * own data.
 *
 * Data Structure:
 * - /users/{userId}/clients/{clientId}: Stores client data owned by the user.
 * - /users/{userId}/clients/{clientId}/budgets/{budgetId}: Stores budget data associated with a client and owned by the user.
 * - /users/{userId}/dailyRates/{dailyRateId}: Stores daily rate configurations owned by the user.
 *
 * Key Security Decisions:
 * - User listing is disallowed to protect user privacy.
 * - All data is private by default and must be explicitly allowed.
 * - The ruleset relies on path-based authorization using the `userId` parameter.
 *
 * Denormalization for Authorization:
 * The data structure denormalizes the `userId` and `clientId` into subcollections,
 * which makes the security rules simpler, more performant and more secure. This avoids having to use costly `get()` calls.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the authenticated user is the owner of the document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper function to check if the authenticated user is the existing owner of the document
    function isExistingOwner(userId) {
      return isSignedIn() && request.auth.uid == userId && exists(resource.data);
    }

    /**
     * @description Secures the user root. No direct access to the /users collection is allowed.
     * @path /users/{userId}
     * @allow N/A - There are no rules at the root /users collection.
     * @deny N/A - There are no rules at the root /users collection.
     * @principle Prevents direct access to the /users collection, enforcing user-level isolation.
     */
    match /users/{userId} {
      // Prevent anyone from creating documents directly under /users.  User accounts are created via Firebase Auth.
      allow get, list, create, update, delete: if false;

          match /clients/{clientId} {
            // Only the owner can read their clients
            allow get, list: if isOwner(userId);

            // Only the owner can create a client, and the userId MUST match the path
            allow create: if isOwner(userId);

            // Only the owner can update or delete a client, and the client must already exist
            allow update, delete: if isExistingOwner(userId);

              match /budgets/{budgetId} {
                // Only the owner can read their budgets
                allow get, list: if isOwner(userId);

                // Only the owner can create a budget
                allow create: if isOwner(userId);

                // Only the owner can update or delete a budget, and the budget must already exist
                allow update, delete: if isExistingOwner(userId);
              }
          }

          match /dailyRates/{dailyRateId} {
            // Only the owner can read their daily rates
            allow get, list: if isOwner(userId);

            // Only the owner can create a daily rate
            allow create: if isOwner(userId);

            // Only the owner can update or delete a daily rate, and the daily rate must already exist
            allow update, delete: if isExistingOwner(userId);
          }
    }
  }
}