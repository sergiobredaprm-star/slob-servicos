/**
 * @fileoverview Firestore and Storage Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Users can only
 * access data and files that they explicitly own. Schema validation is relaxed
 * for rapid prototyping, focusing instead on authorization.
 *
 * Data Structure (Firestore):
 * - /users/{userId}: User profiles.
 * - /users/{userId}/...: All user-specific sub-collections.
 *
 * File Structure (Storage):
 * - /profile-images/{userId}/{fileName}: User profile pictures.
 *
 * Key Security Decisions:
 * - Users can only access/modify their own data and files.
 * - Profile images can be publicly read (as they are used in the UI).
 * - Writes to profile image paths are restricted to the owner and have a size limit.
 * - No global admin roles are defined in this ruleset.
 *
 * Force rule re-deployment.
 */
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Rules for user profiles.  Users can read and write their own profile data.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // No one can list all users.
      allow write: if isOwner(userId);

      // Rules for all subcollections under a user's document
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    /**
     * @description Rules for user profile images.
     * - Anyone can read profile images (for public display).
     * - Only the authenticated owner can upload their own profile image.
     * - Uploads are restricted to a maximum size of 5MB.
     * @path /profile-images/{userId}/{fileName}
     */
    match /profile-images/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId) && isFileSizeOk(5 * 1024 * 1024);
    }
  }
}

// Helper Functions

function isSignedIn() {
  return request.auth != null;
}

function isOwner(userId) {
  return isSignedIn() && request.auth.uid == userId;
}

function isFileSizeOk(maxSizeInBytes) {
  return request.resource.size < maxSizeInBytes;
}
