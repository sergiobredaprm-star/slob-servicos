
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    /**
     * @description Rules for user profile images.
     * - Anyone can read profile images (for public display).
     * - Only the authenticated owner can upload or list their own profile images.
     * @path /profile-images/{userId}/{allPaths=**}
     */
    match /profile-images/{userId}/{allPaths=**} {
      allow read: if true;
      allow list: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
