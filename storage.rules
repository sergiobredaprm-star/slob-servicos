
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    /**
     * @description Rules for user profile images.
     * - Only the authenticated owner can read, list, and write their own profile images.
     * @path /profile-images/{userId}/{allPaths=**}
     */
    match /profile-images/{userId}/{allPaths=**} {
      allow read, list, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
