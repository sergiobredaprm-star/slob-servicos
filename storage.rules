
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    /**
     * @description Rules for user profile images.
     * Separates list and read/write permissions for clarity and correctness.
     */
    
    // Rule to allow a user to LIST the contents of their own image directory.
    match /profile-images/{userId} {
      allow list: if request.auth != null && request.auth.uid == userId;
    }

    // Rule to allow a user to READ and WRITE individual files within their directory.
    match /profile-images/{userId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

